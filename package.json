{
	"name": "starter-template-hono",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"deploy:staging": "wrangler deploy --env staging",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"docker:up": "docker compose up -d",
		"docker:down": "docker-compose down",
		"docker:clean": "docker-compose down -v",
		"docker:seed": "docker exec -i starter-template-hono-postgres psql -U postgres -d starter_template_hono < ./src/db/seeds/create_admin.sql",
		"neon:seed": "psql \"$DATABASE_URL\" -f ./src/db/seeds/create_admin.sql",
		"db:generate": "bun drizzle-kit generate",
		"db:migrate": "bun drizzle-kit migrate",
		"db:migrate:staging": "dotenv -e .env.staging -- drizzle-kit migrate",
		"db:migrate:prod": "dotenv -e .env.production -- drizzle-kit migrate",
		"db:studio": "bun drizzle-kit studio",
		"typecheck": "tsc --noEmit",
		"wrangler:cors": "wrangler secret put CORS_ORIGIN --env staging",
		"wrangler:dburl": "wrangler secret put DATABASE_URL --env staging"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.9",
		"@hono/zod-openapi": "^1.3.0",
		"@neondatabase/serverless": "^1.1.0",
		"@scalar/hono-api-reference": "^0.10.14",
		"better-auth": "^1.6.9",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.16",
		"pg": "^8.20.0",
		"xlsx": "^0.18.5",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@cloudflare/workers-types": "^4.20260504.1",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"wrangler": "^4.4.0"
	}
}
